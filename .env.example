# ============================================================
#  vibe-kit .env.example — 열쇠 보관함 견본
#
#  사용법:  cp .env.example .env   ← 복사한 뒤, "쓰는 서비스"의 값만 진짜 키로 채운다.
#  .env 는 절대 깃허브에 올리지 않는다 (.gitignore 로 차단돼 있음).
#  안 쓰는 서비스는 더미(dummy) 그대로 둬도 된다 — 코드가 "키 없음"을 친절히 알려준다.
# ============================================================

# ─────────── 거의 모두 쓰는 것 ───────────

# Supabase : DB(창고) + 로그인(경비실) + 파일창고 를 빌린다
# 발급: supabase.com → 내 프로젝트 → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=dummy-anon-key
# ⚠️ service_role = 모든 권한을 우회하는 마스터키. 서버 전용 · 일상 작업엔 쓰지 않는다.
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key

# AI : 두뇌를 빌린다 (쓴 만큼 과금)
# 발급: console.anthropic.com → API Keys  /  platform.openai.com → API keys
ANTHROPIC_API_KEY=dummy-anthropic-key
OPENAI_API_KEY=dummy-openai-key

# ─────────── 자주 쓰는 것 ───────────

# Resend : 이메일 발송 (환영 메일·알림). 발급: resend.com
RESEND_API_KEY=dummy-resend-key

# Vercel : 배포. 보통은 깃허브 연결로 끝 — 이 토큰은 CLI로 배포할 때만
VERCEL_TOKEN=dummy-vercel-token

# 소셜 로그인 : 값은 Supabase 대시보드(Authentication → Providers)에 등록한다
# GOOGLE_CLIENT_ID=            (console.cloud.google.com)
# GOOGLE_CLIENT_SECRET=
# KAKAO_CLIENT_ID=             (developers.kakao.com)
# KAKAO_CLIENT_SECRET=

# ─────────── 결제 (⚠️ 반드시 테스트 키부터 — 실제 키 전환은 오픈 직전 맨 마지막) ───────────

# TossPayments : 국내 카드결제. 발급: developers.tosspayments.com
# TOSS_CLIENT_KEY=test_ck_xxx
# TOSS_SECRET_KEY=test_sk_xxx

# Stripe : 해외 결제·구독. 발급: dashboard.stripe.com
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─────────── 선택 재료 (냉동칸 — 쓸 때 꺼냄) ───────────

# Cloudflare : 엣지 배포 · 파일 저장(R2)
CLOUDFLARE_ACCOUNT_ID=dummy-account-id
CLOUDFLARE_API_TOKEN=dummy-cf-token

# Google Sheets : 시트를 DB처럼 (서비스계정)
GOOGLE_SERVICE_ACCOUNT_EMAIL=dummy@project.iam.gserviceaccount.com
GOOGLE_SHEETS_ID=dummy-sheet-id
# GOOGLE_PRIVATE_KEY 는 여러 줄이라 따옴표로 감싼다
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ndummy\n-----END PRIVATE KEY-----\n"

# 카카오 알림톡 · 문자 : solapi.com
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
